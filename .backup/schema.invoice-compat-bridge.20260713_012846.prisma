  rssi      Int?
  snr       Float?
  channel   Int?
  fCnt      Int?
  fPort     Int?
  dr        Int?

  rawPayload    Json?
  parsedPayload Json?

  occurredAt DateTime
  receivedAt DateTime @default(now())

  @@index([deviceId])
  @@index([devEui])
  @@index([parkingLotId])
  @@index([parkingSectionId])
  @@index([parkingSpaceId])
  @@index([eventType])
  @@index([parkingStatus])
  @@index([occurredAt])
  @@index([receivedAt])
}

//////////////////////////////////////////////////////
// AUTH / SECURITY
//////////////////////////////////////////////////////

model EmailVerificationToken {
  id String @id @default(cuid())

  userId String
  email  String

  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@index([usedAt])
}

model PasswordResetToken {
  id String @id @default(cuid())

  userId String
  email  String

  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@index([usedAt])
}

model PasswordHistory {
  id String @id @default(cuid())

  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model LoginAttempt {
  id String @id @default(cuid())

  userId String?
  email  String?

  success Boolean
  reason  String?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([success])
  @@index([createdAt])
}

model ApiKey {
  id String @id @default(cuid())

  ownerType String
  ownerId   String

  keyId   String @unique
  keyHash String

  name   String?
  scopes Json?

  expiresAt DateTime?
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerType, ownerId])
  @@index([keyId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model EdgeNode {
  id String @id @default(cuid())

  code String @unique
  name String

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  status String @default("ACTIVE")

  appVersion      String?
  lastSeenAt      DateTime?
  lastConnectedAt DateTime?
  lastSyncAt      DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keys        EdgeNodeKey[]
  parkingLots EdgeParkingLot[]
  syncCursors SyncCursor[]

  @@index([tenantId])
  @@index([status])
  @@index([lastSeenAt])
}

model EdgeNodeKey {
  id String @id @default(cuid())

  edgeNodeId String
  keyId      String @unique
  keyHash    String

  publicKey String?

  isActive Boolean @default(true)

  expiresAt DateTime?
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edgeNode EdgeNode @relation(fields: [edgeNodeId], references: [id], onDelete: Cascade)

  @@index([edgeNodeId])
  @@index([keyId])
  @@index([isActive])
  @@index([expiresAt])
  @@index([revokedAt])
}

model EdgeParkingLot {
  id String @id @default(cuid())

  edgeNodeId   String
  parkingLotId String

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  edgeNode   EdgeNode   @relation(fields: [edgeNodeId], references: [id], onDelete: Cascade)
  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  @@unique([edgeNodeId, parkingLotId])
  @@index([parkingLotId])
  @@index([isPrimary])
}

model SyncInbox {
  id String @id @default(cuid())

  messageId String @unique

  source       String
  eventType    String
  eventVersion Int    @default(1)

  aggregateType String?
  aggregateId   String?

  payload Json

  status String @default("RECEIVED")

  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  failedAt    DateTime?

  error String?

  @@index([source])
  @@index([eventType])
  @@index([status])
  @@index([receivedAt])
}

model SyncCursor {
  id String @id @default(cuid())

  edgeNodeId String?
  direction  String
  stream     String

  lastSequence  BigInt    @default(0)
  lastMessageId String?
  lastSyncedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edgeNode EdgeNode? @relation(fields: [edgeNodeId], references: [id], onDelete: Cascade)

  @@unique([edgeNodeId, direction, stream])
  @@index([direction])
  @@index([stream])
}

model SyncConflict {
  id String @id @default(cuid())

  messageId String?

  aggregateType String
  aggregateId   String

  conflictType String
  status       String @default("OPEN")

  localPayload  Json?
  remotePayload Json?
  resolution    Json?

  detectedAt DateTime  @default(now())
  resolvedAt DateTime?

  resolvedByUserId String?

  @@index([aggregateType, aggregateId])
  @@index([status])
  @@index([detectedAt])
}

model SensorEventLog {
  id String @id @default(cuid())

  devEui         String
  deviceId       String?
  parkingSpaceId String?

  source    String @default("mqtt")
  eventType String

  parkingStatus   Int?
  deviceStatus    Int?
  batteryStatus   Int?
  batteryVoltage  Float?
  firmwareVersion Int?

  gatewayId String?
  rssi      Int?
  snr       Float?
  channel   Int?
  fCnt      Int?
  fPort     Int?
  dr        Int?

  rawPayload    Json?
  parsedPayload Json?

  occurredAt   DateTime
  createdAt    DateTime      @default(now())
  ParkingSpace ParkingSpace? @relation(fields: [parkingSpaceId], references: [id])

  @@index([devEui])
  @@index([deviceId])
  @@index([parkingSpaceId])
  @@index([eventType])
  @@index([parkingStatus])
  @@index([occurredAt])
  @@index([createdAt])
}

model DisplayBoardModule {
  id String @id @default(cuid())

  displayBoardId String

  rowNo Int
  colNo Int

  parkingSectionId String?

  label   String?
  enabled Boolean @default(true)

  charWidth Int    @default(2)
  padChar   String @default("0")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  displayBoard   DisplayBoard    @relation(fields: [displayBoardId], references: [id], onDelete: Cascade)
  parkingSection ParkingSection? @relation(fields: [parkingSectionId], references: [id], onDelete: SetNull)

  @@unique([displayBoardId, rowNo, colNo])
  @@index([displayBoardId])
  @@index([parkingSectionId])
}

//////////////////////////////////////////////////////
// MOBILE / QR / WATCHER / ENFORCEMENT
//////////////////////////////////////////////////////

model TenantUser {
  id String @id @default(cuid())

  tenantId String
  userId   String
  role     String
  status   String @default("ACTIVE")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, role])
  @@index([userId])
}

model ParkingLotPhoto {
  id String @id @default(cuid())

  parkingLotId String
  imageUrl     String
  sortOrder    Int     @default(0)
  isPrimary    Boolean @default(false)

  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([parkingLotId])
}

model ParkingLotQr {
  id String @id @default(cuid())

  parkingLotId String
  qrToken      String    @unique
  qrType       String    @default("PARKING_LOT")
  isActive     Boolean   @default(true)
  expiresAt    DateTime?

  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parkingLotId])
}

model FavoriteParkingLot {
  id String @id @default(cuid())

  userId       String
  parkingLotId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, parkingLotId])
  @@index([parkingLotId])
}

model ParkingRegistrationPhoto {
  id String @id @default(cuid())

  parkingSessionId String
  imageUrl         String
  photoType        RegistrationPhotoType @default(VEHICLE_PLATE)
  required         Boolean               @default(false)

  capturedByUserId String?
  capturedByRole   String?

  parkingSession ParkingSession @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  capturedBy     User?          @relation(fields: [capturedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([parkingSessionId])
  @@index([capturedByUserId])
}

model WatcherApplication {
  id String @id @default(cuid())

  watcherUserId String
  parkingLotId  String

  status      WatcherApplicationStatus @default(PENDING)
  requestedAt DateTime                 @default(now())

  approvedByUserId String?
  approvedAt       DateTime?
  rejectedByUserId String?
  rejectedAt       DateTime?
  rejectedReason   String?

  watcher    User       @relation("WatcherApplicationWatcher", fields: [watcherUserId], references: [id], onDelete: Cascade)
  approvedBy User?      @relation("WatcherApplicationApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy User?      @relation("WatcherApplicationRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([watcherUserId])
  @@index([parkingLotId, status])
}

model WatcherLotBinding {
  id String @id @default(cuid())

  watcherUserId String
  parkingLotId  String
  status        String @default("ACTIVE")

  watcher    User       @relation(fields: [watcherUserId], references: [id], onDelete: Cascade)
  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([watcherUserId, parkingLotId])
  @@index([parkingLotId])
}

model EnforcementCase {
  id String @id @default(cuid())

  parkingLotId     String
  parkingSectionId String?
  parkingSpaceId   String
  parkingSessionId String

  reason       EnforcementReason
  status       EnforcementCaseStatus @default(OPEN)
  graceMinutes Int

  detectedAt DateTime @default(now())

  assignedToUserId String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  note             String?

  parkingLot     ParkingLot     @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  parkingSession ParkingSession @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  assignedTo     User?          @relation("EnforcementAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  resolvedBy     User?          @relation("EnforcementResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  plateRecognitionResults PlateRecognitionResult[]

  @@index([parkingLotId, status])
  @@index([parkingSessionId])
}

model RegistrationProxyLog {
  id String @id @default(cuid())

  parkingSessionId  String
  performedByUserId String
  performedByRole   String

  vehiclePlateNumber String
  contactPhone       String?
  note               String?

  photoRequired Boolean @default(true)

  parkingSession ParkingSession @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  performedBy    User           @relation(fields: [performedByUserId], references: [id], onDelete: Cascade)

  createdAt                   DateTime                                 @default(now())
  plateRecognitionResults     PlateRecognitionResult[]
  reviewStatus                AuthorityRegistrationReviewStatus        @default(PENDING_REVIEW)
  reviewedByUserId            String?
  reviewedAt                  DateTime?
  reviewNote                  String?
  reviewedBy                  User?                                    @relation("RegistrationProxyLogReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  correctedVehiclePlateNumber String?
  correctedContactPhone       String?
  correctionNote              String?
  correctedByUserId           String?
  correctedAt                 DateTime?
  correctedBy                 User?                                    @relation("RegistrationProxyLogCorrectedBy", fields: [correctedByUserId], references: [id], onDelete: SetNull)
  correctionHistories         AuthorityRegistrationCorrectionHistory[]
  reviewHistories             AuthorityRegistrationReviewHistory[]

  @@index([performedByUserId])
  @@index([parkingSessionId])
  @@index([reviewStatus])
  @@index([reviewedByUserId])
  @@index([correctedByUserId])
  @@index([correctedAt])
}

model InvoiceManualPayment {
  id String @id @default(cuid())

  invoiceId     String
  amount        Int
  paymentMethod String

  collectedByUserId String
  collectedAt       DateTime
  note              String?

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  collectedBy User    @relation(fields: [collectedByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([collectedByUserId])
}

model PlateRecognitionResult {
  id                     String  @id @default(cuid())
  parkingSessionId       String?
  enforcementCaseId      String?
  registrationProxyLogId String?

  imageUrl             String?
  provider             String
  mode                 String
  country              String  @default("KR")
  suggestedPlateNumber String
  reviewedPlateNumber  String?
  confidence           Float?
  candidates           Json?
  rawResponse          Json?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parkingSession       ParkingSession?       @relation(fields: [parkingSessionId], references: [id], onDelete: SetNull)
  enforcementCase      EnforcementCase?      @relation(fields: [enforcementCaseId], references: [id], onDelete: SetNull)
  registrationProxyLog RegistrationProxyLog? @relation(fields: [registrationProxyLogId], references: [id], onDelete: SetNull)
  createdBy            User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([parkingSessionId])
  @@index([enforcementCaseId])
  @@index([registrationProxyLogId])
  @@index([createdByUserId])
  @@index([suggestedPlateNumber])
  @@index([reviewedPlateNumber])
  @@index([createdAt])
}

model AuthorityRegistrationCorrectionHistory {
  id                     String  @id @default(cuid())
  registrationProxyLogId String
  parkingSessionId       String
  correctedByUserId      String?

  previousPlateNumber  String?
  newPlateNumber       String
  previousContactPhone String?
  newContactPhone      String?
  correctionNote       String?

  createdAt DateTime @default(now())

  registrationProxyLog RegistrationProxyLog @relation(fields: [registrationProxyLogId], references: [id], onDelete: Cascade)
  parkingSession       ParkingSession       @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  correctedBy          User?                @relation(fields: [correctedByUserId], references: [id], onDelete: SetNull)

  @@index([registrationProxyLogId])
  @@index([parkingSessionId])
  @@index([correctedByUserId])
  @@index([createdAt])
  @@index([newPlateNumber])
}

model AuthorityRegistrationReviewHistory {
  id                     String  @id @default(cuid())
  registrationProxyLogId String
  reviewedByUserId       String?

  previousStatus AuthorityRegistrationReviewStatus?
  newStatus      AuthorityRegistrationReviewStatus
  reviewNote     String?

  createdAt DateTime @default(now())

  registrationProxyLog RegistrationProxyLog @relation(fields: [registrationProxyLogId], references: [id], onDelete: Cascade)
  reviewedBy           User?                @relation(fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([registrationProxyLogId])
  @@index([reviewedByUserId])
  @@index([newStatus])
  @@index([createdAt])
}


//////////////////////////////////////////////////////
// CONTROL PANEL
//////////////////////////////////////////////////////

model ControlService {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  host        String?
  port        Int?
  commandType String   @default("systemctl")
  targetName  String
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
