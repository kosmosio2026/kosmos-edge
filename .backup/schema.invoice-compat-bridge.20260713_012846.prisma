generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserStatus {
  PENDING_EMAIL_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  LOCKED
  DELETED
}

enum ScopeType {
  GLOBAL
  TENANT
  EDGE
  LOT
  SECTION
  SPACE
  SELF
}

enum SessionStatus {
  CREATED
  ACTIVE
  GRACE_PERIOD
  CLOSED
  PAID
  LOST
  CANCELLED
}

enum SessionType {
  HOURLY
  DAILY
  SUBSCRIPTION
  FREE
  EV_CHARGING
  VIP
}

enum PaymentMethod {
  CARD
  CASH
  MOBILE
  TOSS
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  CANCELLED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum SpaceStatus {
  EMPTY
  OCCUPIED
  RESERVED
  DISABLED
  UNKNOWN
}

enum SpaceType {
  REGULAR
  EV
  HANDICAPPED
  PREGNANT
  COMPACT
  VIP
  RESERVED
}

enum DeviceStatus {
  ACTIVE
  OFFLINE
  FAULT
  MAINTENANCE
}

enum EventPublishStatus {
  NEW
  PROCESSED
  FAILED
}

enum SyncStatus {
  PENDING
  SENT
  FAILED
  ACKED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum SettlementStatus {
  OPEN
  CLOSED
}

enum FaultStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum FaultSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PushNotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ApprovalRequestType {
  MANAGER_LOT_ACCESS
  OPERATOR_SECTION_ACCESS
  MANAGER_REGISTRATION
  MANAGER_SCOPE_ACCESS
  OPERATOR_REGISTRATION
  OPERATOR_SCOPE_ACCESS
  PARKING_LOT_ACCESS
  PARKING_LOT_CREATION
}

enum ReceiptStatus {
  ISSUED
  CANCELLED
}

enum DisplayTransportType {
  TCP
  RS232
  RS485
}

enum DisplayMode {
  AUTO
  MANUAL
}

enum DisplayCommandStatus {
  PENDING
  PROCESSING
  SENT
  ACKED
  FAILED
  CANCELLED
}

enum DisplayBoardStatus {
  OK
  WARN
  ERROR
  OFFLINE
}

enum DisplayLineSource {
  AUTO
  MANUAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ParkingRegion {
  SEOUL
  BUSAN
  DAEGU
  INCHEON
  GWANGJU
  DAEJEON
  ULSAN
  SEJONG
  GYEONGGI
  GANGWON
  CHUNGBUK
  CHUNGNAM
  JEONBUK
  JEONNAM
  GYEONGBUK
  GYEONGNAM
  JEJU
}

enum DeviceType {
  PARKING_SENSOR
  IO_CONTROLLER
  DISPLAY_BOARD
  SMART_TRACKER
  SENSIO_CONTROLLER
}

enum RegistrationStatus {
  UNREGISTERED
  REGISTERED_BY_MEMBER
  REGISTERED_BY_VISITOR
  REGISTERED_BY_WATCHER
  REGISTERED_BY_OPERATOR
  REGISTERED_BY_MANAGER
  REGISTERED_BY_ADMIN
}

enum RegistrationMethod {
  MEMBER_QR
  VISITOR_QR
  WATCHER_PROXY
  OPERATOR_MANUAL
  MANAGER_MANUAL
  ADMIN_MANUAL
}

enum WatcherApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EnforcementCaseStatus {
  OPEN
  IN_PROGRESS
  REGISTERED
  PAID
  DISMISSED
  RESOLVED
}

enum EnforcementReason {
  UNREGISTERED_AFTER_GRACE
  SENSOR_ERROR
  PAYMENT_REQUIRED
  MANUAL_REVIEW
}

enum RegistrationPhotoType {
  VEHICLE_PLATE
  PARKING_SPACE
  DISPUTE_EVIDENCE
}

enum AuthorityRegistrationReviewStatus {
  PENDING_REVIEW
  REVIEWED
  NEEDS_CORRECTION
  REJECTED
}

enum ManualPaymentMethod {
  CASH
  CARD_OFFLINE
  BANK_TRANSFER
  OTHER
}

//////////////////////////////////////////////////////
// USER / AUTH / RBAC
//////////////////////////////////////////////////////

model User {
  id String @id @default(cuid())

  email        String? @unique
  passwordHash String

  name      String
  phone     String?
  birthDate DateTime?

  provider     String?
  providerId   String?
  refreshToken String?

  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  lockedUntil      DateTime?
  failedLoginCount Int       @default(0)

  isApproved Boolean    @default(false)
  status     UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles  UserRole[]
  scopes UserScopeBinding[]

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  passwordHistories       PasswordHistory[]
  loginAttempts           LoginAttempt[]

  managerProfile  ManagerProfile?
  operatorProfile OperatorProfile?
  memberProfile   MemberProfile?
  visitorProfile  VisitorProfile?
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  vehicles        UserVehicle[]

  parkingSessions ParkingSession[]

  entryRecords EntryRecord[]
  exitRecords  ExitRecord[]

  subscriptions Subscription[]
  outstandings  Outstanding[]

  issuedReceipts Receipt[] @relation("ReceiptIssuedBy")
  ownedReceipts  Receipt[] @relation("ReceiptOwner")

  assignedFaults DeviceFault[] @relation("FaultAssignee")

  approvalRequestsSubmitted ApprovalRequest[] @relation("ApprovalRequester")
  approvalRequestsReviewed  ApprovalRequest[] @relation("ApprovalReviewer")

  approvedManagers  ManagerProfile[]  @relation("ManagerApprovedBy")
  approvedOperators OperatorProfile[] @relation("OperatorApprovedBy")

  pushTokens           PushToken[]
  createdNotifications PushNotification[]

  authSessions                             Session[]
  auditLogs                                AuditLog[]
  userDevices                              UserDevice[]
  MonthlySubscription                      MonthlySubscription[]
  tenantUsers                              TenantUser[]
  favoriteParkingLots                      FavoriteParkingLot[]
  watcherApplications                      WatcherApplication[]                     @relation("WatcherApplicationWatcher")
  watcherApplicationsApproved              WatcherApplication[]                     @relation("WatcherApplicationApprovedBy")
  watcherApplicationsRejected              WatcherApplication[]                     @relation("WatcherApplicationRejectedBy")
  watcherLotBindings                       WatcherLotBinding[]
  registrationPhotos                       ParkingRegistrationPhoto[]
  registrationProxyLogs                    RegistrationProxyLog[]
  enforcementAssigned                      EnforcementCase[]                        @relation("EnforcementAssignedTo")
  enforcementResolved                      EnforcementCase[]                        @relation("EnforcementResolvedBy")
  invoiceManualPayments                    InvoiceManualPayment[]
  plateRecognitionResults                  PlateRecognitionResult[]
  reviewedRegistrationProxyLogs            RegistrationProxyLog[]                   @relation("RegistrationProxyLogReviewedBy")
  correctedRegistrationProxyLogs           RegistrationProxyLog[]                   @relation("RegistrationProxyLogCorrectedBy")
  authorityRegistrationCorrectionHistories AuthorityRegistrationCorrectionHistory[]
  authorityRegistrationReviewHistories     AuthorityRegistrationReviewHistory[]
}

model Role {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        UserRole[]
  permissions  RolePermission[]
  menuPolicies RoleMenuPolicy[]
  pagePolicies RolePagePolicy[]

  @@index([createdAt])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String?
  module      String?
  action      String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]

  @@index([module])
  @@index([action])
  @@index([createdAt])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model AppMenu {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  path      String?
  icon      String?
  parentId  String?
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   AppMenu?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: SetNull)
  children AppMenu[] @relation("MenuTree")

  pages        AppPage[]
  rolePolicies RoleMenuPolicy[]

  @@index([parentId])
  @@index([sortOrder])
  @@index([isVisible])
}

model AppPage {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  route       String   @unique
  module      String
  description String?
  menuId      String?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menu         AppMenu?         @relation(fields: [menuId], references: [id], onDelete: SetNull)
  actions      PageAction[]
  rolePolicies RolePagePolicy[]

  @@index([menuId])
  @@index([module])
  @@index([sortOrder])
  @@index([isVisible])
}

model PageAction {
  id            String   @id @default(cuid())
  pageId        String
  code          String
  name          String
  permissionKey String?
  createdAt     DateTime @default(now())

  page AppPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, code])
  @@index([permissionKey])
}

model MenuPolicy {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  href        String
  group       String
  order       Int
  scopeLevel  String?
  description String?
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roleMenus RoleMenuPolicy[]
}

model RoleMenuPolicy {
  id           String    @id @default(cuid())
  roleId       String
  menuId       String
  menuPolicyId String?
  canView      Boolean   @default(true)
  scopeType    ScopeType @default(GLOBAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role       Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menuPolicy MenuPolicy? @relation(fields: [menuPolicyId], references: [id], onDelete: Cascade)
  menu       AppMenu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@unique([roleId, menuPolicyId])
  @@index([roleId])
  @@index([menuId])
  @@index([scopeType])
}

model RolePagePolicy {
  id         String    @id @default(cuid())
  roleId     String
  pageId     String
  canView    Boolean   @default(true)
  canCreate  Boolean   @default(false)
  canUpdate  Boolean   @default(false)
  canDelete  Boolean   @default(false)
  canApprove Boolean   @default(false)
  canExport  Boolean   @default(false)
  scopeType  ScopeType @default(GLOBAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  page AppPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([roleId, pageId])
  @@index([roleId])
  @@index([pageId])
  @@index([scopeType])
}

model UserScopeBinding {
  id               String    @id @default(cuid())
  userId           String
  scopeType        ScopeType
  parkingLotId     String?
  parkingSectionId String?
  parkingSpaceId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parkingLot     ParkingLot?     @relation(fields: [parkingLotId], references: [id], onDelete: SetNull)
  parkingSection ParkingSection? @relation(fields: [parkingSectionId], references: [id], onDelete: SetNull)
  parkingSpace   ParkingSpace?   @relation(fields: [parkingSpaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, scopeType])
  @@index([parkingLotId])
  @@index([parkingSectionId])
  @@index([parkingSpaceId])
}

//////////////////////////////////////////////////////
// VEHICLE
//////////////////////////////////////////////////////

model Vehicle {
  id String @id @default(cuid())

  plateNumber String @unique

  vehicleType String?
  ownerName   String?

  memberProfileId String?
  memberProfile   MemberProfile? @relation(fields: [memberProfileId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userLinks UserVehicle[]

  sessions     ParkingSession[]
  EntryRecord  EntryRecord[]
  ExitRecord   ExitRecord[]
  Subscription Subscription[]

  @@index([plateNumber])
}

//////////////////////////////////////////////////////
// PROFILES
//////////////////////////////////////////////////////

model MemberProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone            String?
  vehicles         Vehicle[]
  vehicleNo        String?
  membershipNo     String?
  emergencyContact String?
  billingAutoPay   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VisitorProfile {
  userId String @id

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone               String?
  vehicleNo           String?
  pinCodeHash         String?
  note                String?
  phoneVerified       Boolean   @default(false)
  agreedAt            DateTime?
  lastAuthenticatedAt DateTime?
  expiresAt           DateTime?
  visitPurpose        String?
  hostName            String?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  ParkingSession ParkingSession[]
}

model ManagerProfile {
  userId String @id

  user User @relation(fields: [userId], references: [id])

  companyName String
  department  String?

  isApproved   Boolean   @default(false)
  approvedAt   DateTime?
  approvedById String?

  parkingLots ManagerParkingLot[]

  approvedBy User? @relation("ManagerApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
}

model OperatorProfile {
  userId String @id

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeNo        String?
  companyName       String?
  shiftType         String?
  emergencyContact String?

  isApproved   Boolean   @default(false)
  approvedAt   DateTime?
  approvedById String?

  parkingSections OperatorParkingSection[]

  approvedBy User? @relation("OperatorApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// PARKING CORE
//////////////////////////////////////////////////////

model ParkingLot {
  id   String @id @default(cuid())
  name String
  code String @unique

  region   String?
  address  String?
  district String?
  timezone String  @default("Asia/Seoul")

  lat Float?
  lng Float?

  centerLat Float?
  centerLng Float?

  representative String?
  contact        String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edgeParkingLots        EdgeParkingLot[]
  sections               ParkingSection[]
  fees                   Fee[]
  feePolicies            FeePolicy[]
  sensorDevices          SensorDevice[]
  scopes                 UserScopeBinding[]
  approvalRequests       ApprovalRequest[]
  subscriptions          Subscription[]
  settlements            DailySettlement[]
  MonthlySubscription    MonthlySubscription[]
  Device                 Device[]
  ManagerParkingLot      ManagerParkingLot[]
  OperatorParkingSection OperatorParkingSection[]
  displayBoard           DisplayBoard?
  description            String?
  operationHours         Json?
  graceMinutes           Int                      @default(10)

  photos              ParkingLotPhoto[]
  qrCodes             ParkingLotQr[]
  favorites           FavoriteParkingLot[]
  watcherApplications WatcherApplication[]
  watcherBindings     WatcherLotBinding[]
  enforcementCases    EnforcementCase[]

  @@index([name])
  @@index([region])
  @@index([isActive])
  @@index([createdAt])
}

model ParkingSection {
  id           String  @id @default(cuid())
  name         String
  code         String?
  parkingLotId String

  centerLat   Float?
  centerLng   Float?
  polygonJson Json?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parkingLot             ParkingLot               @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  spaces                 ParkingSpace[]
  sensorDevices          SensorDevice[]
  scopes                 UserScopeBinding[]
  approvalRequests       ApprovalRequest[]
  Device                 Device[]
  OperatorParkingSection OperatorParkingSection[]
  DisplayBoardModule     DisplayBoardModule[]

  @@unique([parkingLotId, code])
  @@index([parkingLotId])
  @@index([name])
  @@index([isActive])
  @@index([createdAt])
}

model ParkingSpaceTypeStyle {
  id           String    @id @default(cuid())
  type         SpaceType @unique
  label        String
  description  String?
  strokeColor  String    @default("#475569")
  fillColor    String    @default("#E5E7EB")
  textColor    String    @default("#0F172A")
  iconKey      String?
  iconUrl      String?
  displayOrder Int       @default(100)
  isActive     Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, displayOrder])
}

model ParkingSpace {
  id        String  @id @default(cuid())
  code      String
  number    String?
  sectionId String

  type         SpaceType     @default(REGULAR)
  status       SpaceStatus   @default(EMPTY)
  deviceFaults DeviceFault[] // ← 이게 없어서 오류 발생

  lat         Float?
  lng         Float?
  widthMeter  Float?
  heightMeter Float?
  rotationDeg Float?
  posX        Float?
  posY        Float?
  polygonJson Json?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section         ParkingSection     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sessions        ParkingSession[]
  entryRecords    EntryRecord[]
  exitRecords     ExitRecord[]
  sensorDevice    SensorDevice?
  sensorEventLogs SensorEventLog[]
  scopes          UserScopeBinding[]
  Device          Device[]

  @@unique([sectionId, code])
  @@index([sectionId])
  @@index([status])
  @@index([isActive])
  @@index([createdAt])
}

model ManagerParkingLot {
  id                   String   @id @default(cuid())
  managerProfileUserId String
  parkingLotId         String
  createdAt            DateTime @default(now())

  managerProfile ManagerProfile @relation(fields: [managerProfileUserId], references: [userId], onDelete: Cascade)
  parkingLot     ParkingLot     @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  @@unique([managerProfileUserId, parkingLotId])
}

model OperatorParkingSection {
  id                    String   @id @default(cuid())
  operatorProfileUserId String
  parkingLotId          String
  sectionId             String
  createdAt             DateTime @default(now())

  operatorProfile OperatorProfile @relation(fields: [operatorProfileUserId], references: [userId], onDelete: Cascade)
  parkingLot      ParkingLot      @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  section         ParkingSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([operatorProfileUserId, sectionId])
}

//////////////////////////////////////////////////////
// PARKING SESSION / EVENT-DRIVEN DOMAIN
//////////////////////////////////////////////////////

model ParkingSession {
  id        String @id @default(cuid())
  sessionNo String @unique

  userId         String?
  vehicleId      String?
  parkingSpaceId String?
  plateNumber    String? // 🔥 추가

  sessionType SessionType   @default(HOURLY)
  status      SessionStatus @default(CREATED)

  entryGate String?
  exitGate  String?

  entryTime       DateTime?
  exitTime        DateTime?
  graceStartedAt  DateTime?
  billingClosedAt DateTime?

  totalMinutes Int?
  amount       Int?
  paidAmount   Int?
  unpaidAmount Int?

  feePolicyId String?

  isRegistered Boolean   @default(false)
  registeredAt DateTime?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  vehicle   Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  feePolicy FeePolicy? @relation(fields: [feePolicyId], references: [id], onDelete: SetNull)

  events                                   ParkingSessionEvent[]
  invoices                                  Invoice[]
  receipts                                 Receipt[]
  ParkingSpace                             ParkingSpace?                            @relation(fields: [parkingSpaceId], references: [id])
  registrationStatus                       RegistrationStatus                       @default(UNREGISTERED)
  registrationMethod                       RegistrationMethod?
  registeredByUserId                       String?
  contactPhone                             String?
  visitorProfileUserId                     String?
  visitorProfile                           VisitorProfile?                          @relation(fields: [visitorProfileUserId], references: [userId], onDelete: SetNull)
  registrationPhotos                       ParkingRegistrationPhoto[]
  proxyLogs                                RegistrationProxyLog[]
  enforcementCases                         EnforcementCase[]
  plateRecognitionResults                  PlateRecognitionResult[]
  authorityRegistrationCorrectionHistories AuthorityRegistrationCorrectionHistory[]

  @@index([userId])
  @@index([vehicleId])
  @@index([parkingSpaceId])
  @@index([status])
  @@index([entryTime])
  @@index([registeredAt])
  @@index([createdAt])
}

model ParkingSessionEvent {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  source    String
  payload   Json?
  createdAt DateTime @default(now())

  session ParkingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([type])
}

//////////////////////////////////////////////////////
// PAYMENT / INVOICE
//////////////////////////////////////////////////////

model Invoice {
  id        String @id @default(cuid())
  invoiceNo String @unique
  sessionId String

  status InvoiceStatus @default(DRAFT)

  amount         Int
  discountAmount Int @default(0)
  paidAmount     Int @default(0)
  unpaidAmount   Int @default(0)

  baseParkingAmount                 Int @default(0)
  registrationGraceDiscountAmount   Int @default(0)
  authorityRegistrationSurchargeAmount Int @default(0)
  watcherRewardBasisAmount          Int @default(0)
  finalAmount                       Int @default(0)

  issuedAt DateTime?
  dueAt    DateTime?
  paidAt   DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session        ParkingSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  payments       Payment[]
  receipts       Receipt[]
  manualPayments InvoiceManualPayment[]

  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id        String @id @default(cuid())
  orderId   String @unique
  invoiceId String
  amount    Int

  method PaymentMethod
  status PaymentStatus @default(PENDING)

  receipt Receipt?

  tossPaymentKey     String? @unique
  tossOrderId        String? @unique
  tossTransactionKey String?

  approvedAt     DateTime?
  failedAt       DateTime?
  cancelledAt    DateTime?
  failureCode    String?
  failureMessage String?
  rawResponse    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
  @@index([createdAt])
}

model PaymentTransaction {
  id            String @id @default(cuid())
  transactionNo String @unique

  invoiceId        String
  parkingSessionId String?

  provider String
  method   String?
  status   String  @default("REQUESTED")

  amount   Int
  currency String @default("KRW")

  providerOrderId    String?
  providerPaymentKey String?
  providerReference  String?

  approvedAt  DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?

  failureCode    String?
  failureMessage String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Receipt {
  id             String  @id @default(cuid())
  receiptNo      String  @unique
  paymentId      String  @unique
  invoiceId      String?
  sessionId      String?
  issuedByUserId String?
  ownerUserId    String?
  ownerPhone     String?
  ownerName      String?

  status ReceiptStatus @default(ISSUED)

  supplyAmount Int
  taxAmount    Int @default(0)
  totalAmount  Int

  issuedAt    DateTime  @default(now())
  cancelledAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment      Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice      Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  session      ParkingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  issuedByUser User?           @relation("ReceiptIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  ownerUser    User?           @relation("ReceiptOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([invoiceId])
  @@index([sessionId])
  @@index([ownerUserId])
  @@index([issuedAt])
}

//////////////////////////////////////////////////////
// LEGACY ENTRY / EXIT RECORDS
// Keep for migration, auditing, or compatibility.
// Can be phased out later if ParkingSessionEvent fully replaces them.
//////////////////////////////////////////////////////

model EntryRecord {
  id String @id @default(cuid())

  userId         String
  vehicleId      String?
  parkingSpaceId String

  enteredAt DateTime @default(now())
  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  parkingSpace ParkingSpace @relation(fields: [parkingSpaceId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([vehicleId])
  @@index([parkingSpaceId])
  @@index([enteredAt])
}

model ExitRecord {
  id String @id @default(cuid())

  userId         String
  vehicleId      String?
  parkingSpaceId String?

  fee       Float    @default(0)
  exitedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  ParkingSpace ParkingSpace? @relation(fields: [parkingSpaceId], references: [id])

  @@index([userId])
  @@index([vehicleId])
  @@index([parkingSpaceId])
  @@index([exitedAt])
}

//////////////////////////////////////////////////////
// FEES / DISCOUNTS / BILLING SETTINGS
//////////////////////////////////////////////////////

model Fee {
  id          String  @id @default(cuid())
  name        String
  description String?

  baseAmount  Int
  perHour     Int
  maxDaily    Int?
  vehicleType String

  parkingLotId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parkingLot       ParkingLot        @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  discountPrograms DiscountProgram[]

  @@index([parkingLotId])
  @@index([vehicleType])
  @@index([createdAt])
}

model FeePolicy {
  id String @id @default(cuid())

  parkingLotId String
  code         String?
  name         String?
  vehicleType  String

  baseMinutes           Int
  baseFee               Int
  unitMinutes           Int
  unitFee               Int
  memberDiscountPercent Int @default(0)

  dailyMax         Int?
  graceMinutes     Int  @default(0) // 최초 입차 무료 회차 시간
  exitGraceMinutes Int  @default(10) // 결제 후 출차 유예 시간

  registrationGraceMinutes Int @default(10) // 입차 후 직접 등록 유예 시간
  registrationGraceFee     Int @default(0)  // 등록 유예 시간에 해당하는 요금
  registrationGraceDiscountEnabled Boolean @default(true)
  authorityRegistrationGraceDiscountEnabled Boolean @default(false)
  watcherRewardGraceFeeEnabled Boolean @default(false)

  // 🔥 이거 추가 (필수)
  timeRules FeePolicyTimeRule[]

  isActive  Boolean   @default(true)
  validFrom DateTime?
  validTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parkingLot ParkingLot       @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  sessions   ParkingSession[]

  @@unique([parkingLotId, code])
  @@index([parkingLotId])
  @@index([vehicleType])
  @@index([isActive])
  @@index([createdAt])
}

model FeePolicyTimeRule {
  id String @id @default(cuid())

  feePolicyId String
  startHour   Int
  endHour     Int

  multiplier Float @default(1.0)

  feePolicy FeePolicy @relation(fields: [feePolicyId], references: [id])
}

model DiscountProgram {
  id         String  @id @default(cuid())
  name       String
  percentage Float
  isActive   Boolean @default(true)

  feeId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fee Fee @relation(fields: [feeId], references: [id], onDelete: Cascade)

  @@index([feeId])
  @@index([isActive])
}

model MonthlySubscription {
  id            String     @id @default(uuid())
  userId        String
  parkingLotId  String
  vehicleNumber String
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id])
  parkingLot    ParkingLot @relation(fields: [parkingLotId], references: [id])
}

model Coupon {
  id String @id @default(cuid())

  code         String       @unique
  discountType DiscountType
  value        Int

  expiresAt  DateTime?
  usageLimit Int?
  usedCount  Int       @default(0)
  isActive   Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@index([isActive])
  @@index([createdAt])
}

model MonthlyCharge {
  id           String  @id @default(cuid())
  userId       String?
  parkingLotId String?
  amount       Float
  status       String
  billingMonth String?
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([parkingLotId])
  @@index([status])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// AUTH SESSION / USER DEVICE
//////////////////////////////////////////////////////

model Session {
  id               String   @id @default(uuid())
  userId           String
  deviceId         String
  userAgent        String?
  ip               String?
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([createdAt])
}

model UserDevice {
  id         String   @id @default(cuid())
  userId     String
  userAgent  String
  ip         String
  deviceName String?
  platform   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// SENSOR / DEVICE / EDGE IOT
//////////////////////////////////////////////////////

model SensorDevice {
  id           String  @id @default(uuid())
  name         String
  type         String
  serialNumber String  @unique
  devEui       String? @unique
  macAddress   String? @unique
  ipAddress    String?
  installLocation String?

  status DeviceStatus  @default(ACTIVE)
  faults DeviceFault[]

  parkingLotId     String?
  parkingSectionId String?
  parkingSpaceId   String? @unique

  firmwareVersion String?
  lastSeenAt      DateTime?
  metadata        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parkingLot     ParkingLot?     @relation(fields: [parkingLotId], references: [id], onDelete: SetNull)
  parkingSection ParkingSection? @relation(fields: [parkingSectionId], references: [id], onDelete: SetNull)
  parkingSpace   ParkingSpace?   @relation(fields: [parkingSpaceId], references: [id], onDelete: SetNull)

  events SensorEvent[]

  @@index([parkingLotId])
  @@index([parkingSectionId])
  @@index([status])
  @@index([lastSeenAt])
  @@index([createdAt])
}

model SensorEvent {
  id             String             @id @default(cuid())
  sensorDeviceId String
  eventType      String
  payload        Json
  receivedAt     DateTime           @default(now())
  publishStatus  EventPublishStatus @default(NEW)

  sensorDevice SensorDevice @relation(fields: [sensorDeviceId], references: [id], onDelete: Cascade)

  @@index([sensorDeviceId, receivedAt])
  @@index([publishStatus])
  @@index([eventType])
}

//////////////////////////////////////////////////////
// DOMAIN EVENT / CLOUD SYNC OUTBOX
//////////////////////////////////////////////////////

model DomainEvent {
  id            String             @id @default(cuid())
  eventId       String             @unique
  aggregateType String
  aggregateId   String
  eventType     String
  eventVersion  Int                @default(1)
  payload       Json
  occurredAt    DateTime
  createdAt     DateTime           @default(now())
  publishStatus EventPublishStatus @default(NEW)

  outboxes SyncOutbox[]

  @@index([aggregateType, aggregateId])
  @@index([publishStatus])
  @@index([occurredAt])
  @@index([createdAt])
}

model SyncOutbox {
  id            String     @id @default(cuid())
  domainEventId String
  destination   String
  status        SyncStatus @default(PENDING)
  retryCount    Int        @default(0)
  nextRetryAt   DateTime?
  lastError     String?
  sentAt        DateTime?
  ackedAt       DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  domainEvent DomainEvent @relation(fields: [domainEventId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([destination])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// AUDIT
//////////////////////////////////////////////////////

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// SUBSCRIPTION
//////////////////////////////////////////////////////

model Subscription {
