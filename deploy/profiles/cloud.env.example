APP_PROFILE=cloud
NODE_ENV=production

API_PORT=3000
WEB_PORT=4000
PORT=3000

NEXT_PUBLIC_APP_PROFILE=cloud
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000
NEXT_DIST_DIR=.next-cloud

DB_RUNTIME=external
POSTGRES_IMAGE=postgres:18
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5434
POSTGRES_DB=parking_cloud
POSTGRES_USER=kosmos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_VOLUME_NAME=kosmos-cloud-postgres-data
POSTGRES_SYSTEMD_UNIT=

DATABASE_URL='postgresql://kosmos:CHANGE_ME@127.0.0.1:5434/parking_cloud?schema=public'

JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

INSTALL_SEED_MODE=production
BOOTSTRAP_ROLE=ADMIN
BOOTSTRAP_EMAIL=admin@customer.local
BOOTSTRAP_NAME='Cloud Administrator'
BOOTSTRAP_PASSWORD=CHANGE_ME

EDGE_SYNC_WORKER_ENABLED=false
EDGE_CLOUD_PUSH_WORKER_ENABLED=false

START_SERVICES_AFTER_INSTALL=false
