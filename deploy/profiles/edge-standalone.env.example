APP_PROFILE=edge-standalone
NODE_ENV=production

API_PORT=3002
WEB_PORT=4002
PORT=3002

NEXT_PUBLIC_APP_PROFILE=edge-standalone
NEXT_PUBLIC_API_URL=http://127.0.0.1:3002
NEXT_DIST_DIR=.next-edge-standalone

DB_RUNTIME=external
POSTGRES_IMAGE=postgres:18
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5436
POSTGRES_DB=parking_edge_standalone
POSTGRES_USER=kosmos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_VOLUME_NAME=kosmos-edge-standalone-postgres-data
POSTGRES_SYSTEMD_UNIT=

DATABASE_URL='postgresql://kosmos:CHANGE_ME@127.0.0.1:5436/parking_edge_standalone?schema=public'

JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

INSTALL_SEED_MODE=production
BOOTSTRAP_ROLE=MANAGER
BOOTSTRAP_EMAIL=manager@customer.local
BOOTSTRAP_NAME='Standalone Parking Manager'
BOOTSTRAP_PASSWORD=CHANGE_ME

EDGE_SYNC_WORKER_ENABLED=false
EDGE_CLOUD_PUSH_WORKER_ENABLED=false

START_SERVICES_AFTER_INSTALL=false
