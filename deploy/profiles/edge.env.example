APP_PROFILE=edge
NODE_ENV=production

API_PORT=3001
WEB_PORT=4001
PORT=3001

NEXT_PUBLIC_APP_PROFILE=edge
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
NEXT_DIST_DIR=.next-edge

DB_RUNTIME=external
POSTGRES_IMAGE=postgres:18
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5435
POSTGRES_DB=parking_edge
POSTGRES_USER=kosmos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_VOLUME_NAME=kosmos-edge-postgres-data
POSTGRES_SYSTEMD_UNIT=

DATABASE_URL='postgresql://kosmos:CHANGE_ME@127.0.0.1:5435/parking_edge?schema=public'

JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

INSTALL_SEED_MODE=production
BOOTSTRAP_ROLE=MANAGER
BOOTSTRAP_EMAIL=manager@customer.local
BOOTSTRAP_NAME='Parking Manager'
BOOTSTRAP_PASSWORD=CHANGE_ME

EDGE_SYNC_WORKER_ENABLED=true
EDGE_CLOUD_PUSH_WORKER_ENABLED=true

START_SERVICES_AFTER_INSTALL=false
