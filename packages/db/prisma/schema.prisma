/// Tenant가 선불로 구매하는 할인권 상품이다.
model TenantCouponProduct {
  id String @id @default(cuid())

  parkingLotId String
  code         String
  name         String
  description  String?

  benefitType  DiscountBenefitType
  benefitValue Int
  salePrice    Int

  validityMonths                 Int     @default(1)
  stackableWithAutomaticDiscount Boolean @default(true)
  isActive                       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parkingLot ParkingLot             @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  purchases  TenantCouponPurchase[]
  coupons    TenantCoupon[]

  @@unique([parkingLotId, code])
  @@index([parkingLotId, isActive])
  @@index([createdAt])
}

/// Tenant의 할인권 구매 요청, 입금 확인 및 수량 발행 기록이다.
model TenantCouponPurchase {
  id         String @id @default(cuid())
  purchaseNo String @unique

  tenantId  String
  productId String

  quantity    Int
  unitPrice   Int
  totalAmount Int
  paidAmount  Int @default(0)

  status           TenantCouponPurchaseStatus @default(PAYMENT_PENDING)
  paymentReference String?
  memo             String?

  requestedByUserId        String?
  paymentConfirmedByUserId String?

  requestedAt        DateTime  @default(now())
  paymentConfirmedAt DateTime?
  issuedAt           DateTime?
  expiresAt          DateTime?
  cancelledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product            TenantCouponProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  requestedBy        User?               @relation("TenantCouponPurchaseRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  paymentConfirmedBy User?               @relation("TenantCouponPurchaseConfirmedBy", fields: [paymentConfirmedByUserId], references: [id], onDelete: SetNull)
  coupons            TenantCoupon[]

  @@index([tenantId, status])
  @@index([productId])
  @@index([requestedAt])
  @@index([paymentConfirmedAt])
}

/// 실제 1회 사용 가능한 개별 할인권이다.
model TenantCoupon {
  id       String @id @default(cuid())
  serialNo String @unique

  codeHash   String @unique
  codeMasked String

  tenantId   String
  productId  String
  purchaseId String

  status    TenantCouponStatus @default(AVAILABLE)
  expiresAt DateTime

  assignedMemberUserId String?
  assignedByUserId     String?
  assignedAt           DateTime?

  reservedSessionId    String?   @unique
  reservationToken     String?   @unique
  reservationExpiresAt DateTime?

  usedSessionId String?   @unique
  usedInvoiceId String?
  usedAt        DateTime?

  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  TenantCouponProduct  @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchase TenantCouponPurchase @relation(fields: [purchaseId], references: [id], onDelete: Restrict)

  assignedMember User? @relation("TenantCouponAssignedMember", fields: [assignedMemberUserId], references: [id], onDelete: SetNull)
  assignedBy     User? @relation("TenantCouponAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  reservedSession ParkingSession? @relation("TenantCouponReservedSession", fields: [reservedSessionId], references: [id], onDelete: SetNull)
  usedSession     ParkingSession? @relation("TenantCouponUsedSession", fields: [usedSessionId], references: [id], onDelete: SetNull)
  usedInvoice     Invoice?        @relation("TenantCouponUsedInvoice", fields: [usedInvoiceId], references: [id], onDelete: SetNull)

  events TenantCouponEvent[]

  @@index([tenantId, status])
  @@index([productId, status])
  @@index([purchaseId])
  @@index([assignedMemberUserId, status])
  @@index([expiresAt])
  @@index([usedInvoiceId])
}

/// 할인권 발행, 증정, 예약, 사용 이력을 기록한다.
model TenantCouponEvent {
  id String @id @default(cuid())

  couponId   String
  eventType  TenantCouponEventType
  fromStatus TenantCouponStatus?
  toStatus   TenantCouponStatus?

  actorUserId      String?
  memberUserId     String?
  parkingSessionId String?
  invoiceId        String?

  metadata  Json?
  createdAt DateTime @default(now())

  coupon         TenantCoupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  actor          User?           @relation("TenantCouponEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  member         User?           @relation("TenantCouponEventMember", fields: [memberUserId], references: [id], onDelete: SetNull)
  parkingSession ParkingSession? @relation(fields: [parkingSessionId], references: [id], onDelete: SetNull)
  invoice        Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([couponId, createdAt])
  @@index([eventType])
  @@index([actorUserId])
  @@index([memberUserId])
  @@index([parkingSessionId])
  @@index([invoiceId])
}

model TenantUser {
  id String @id @default(cuid())

  tenantId String
  userId   String
  role     String
  status   String @default("ACTIVE")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pinHash     String?
  lastLoginAt DateTime?

  @@unique([tenantId, userId, role])
  @@index([userId])
  @@index([tenantId])
  @@index([status])
}

model TenantAppCredential {
  id String @id @default(cuid())

  tenantId       String @unique
  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessNumber String @unique
  pinHash        String

  lastLoginAt  DateTime?
  pinUpdatedAt DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visitConfirmations TenantVisitConfirmation[] @relation("TenantVisitConfirmedByCredential")

  @@index([businessNumber])
  @@index([tenantId])
}

model TenantApplication {
  id                  String             @id @default(cuid())
  parkingLotId        String
  parkingLot          ParkingLot         @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  managementCompanyId String?
  managementCompany   ManagementCompany? @relation(fields: [managementCompanyId], references: [id], onDelete: SetNull)
  tenantId            String?
  tenant              Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  companyName    String
  businessNumber String?
  representative String?
  contact        String?
  billingEmail   String?
  applicantName  String?
  applicantPhone String?
  applicantEmail String?
  memo           String?

  status TenantApplicationStatus @default(PENDING)

  approvedAt       DateTime?
  approvedByUserId String?
  approvedBy       User?     @relation("TenantApplicationApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  rejectedAt       DateTime?
  rejectedByUserId String?
  rejectedBy       User?     @relation("TenantApplicationRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  rejectReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pinHash String?

  @@index([parkingLotId])
  @@index([managementCompanyId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([businessNumber])
}

model TenantVisitConfirmation {
  id String @id @default(cuid())

  tenantId         String
  parkingSessionId String
  parkingLotId     String
  parkingSectionId String?
  parkingSpaceId   String?

  confirmedByUserId       String?
  confirmedByCredentialId String?
  confirmedAt             DateTime @default(now())

  vehiclePlate String?
  contactPhone String?
  entryTime    DateTime?

  coveredAmount Int       @default(0)
  coveredUntil  DateTime?

  graceMinutes Int
  graceUntil   DateTime?

  note   String?
  status TenantVisitConfirmationStatus @default(CONFIRMED)

  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parkingSession        ParkingSession       @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  parkingLot            ParkingLot           @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  parkingSpace          ParkingSpace?        @relation(fields: [parkingSpaceId], references: [id], onDelete: SetNull)
  confirmedByUser       User?                @relation("TenantVisitConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  confirmedByCredential TenantAppCredential? @relation("TenantVisitConfirmedByCredential", fields: [confirmedByCredentialId], references: [id], onDelete: SetNull)

  charges TenantCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parkingSessionId, tenantId])
  @@index([tenantId])
  @@index([parkingSessionId])
  @@index([parkingLotId])
  @@index([parkingSpaceId])
  @@index([confirmedByUserId])
  @@index([confirmedByCredentialId])
  @@index([confirmedAt])
  @@index([status])
}

model TenantCharge {
  id String @id @default(cuid())

  tenantId                  String
  parkingSessionId          String
  tenantVisitConfirmationId String?
  parkingLotId              String
  parkingSpaceId            String?

  chargeType   TenantChargeType
  amount       Int
  occurredAt   DateTime
  billingMonth String

  status TenantChargeStatus @default(PENDING)
  memo   String?

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parkingSession          ParkingSession           @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  tenantVisitConfirmation TenantVisitConfirmation? @relation(fields: [tenantVisitConfirmationId], references: [id], onDelete: SetNull)
  parkingLot              ParkingLot               @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  parkingSpace            ParkingSpace?            @relation(fields: [parkingSpaceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([parkingSessionId])
  @@index([tenantVisitConfirmationId])
  @@index([parkingLotId])
  @@index([parkingSpaceId])
  @@index([billingMonth])
  @@index([status])
  @@index([occurredAt])
}

model TenantMonthlyStatement {
  id String @id @default(cuid())

  tenantId            String
  parkingLotId        String
  managementCompanyId String

  billingMonth String
  totalAmount  Int    @default(0)
  visitCount   Int    @default(0)

  status TenantMonthlyStatementStatus @default(DRAFT)

  closedAt       DateTime?
  closedByUserId String?
  memo           String?

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parkingLot        ParkingLot        @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  managementCompany ManagementCompany @relation(fields: [managementCompanyId], references: [id], onDelete: Cascade)
  closedByUser      User?             @relation("TenantStatementClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, billingMonth])
  @@index([parkingLotId])
  @@index([managementCompanyId])
  @@index([billingMonth])
  @@index([status])
  @@index([closedByUserId])
}

model ParkingLotPhoto {
  id String @id @default(cuid())

  parkingLotId String
  imageUrl     String
  sortOrder    Int     @default(0)
  isPrimary    Boolean @default(false)

  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([parkingLotId])
}

model ParkingLotQr {
  id String @id @default(cuid())

  parkingLotId String
  qrToken      String    @unique
  qrType       String    @default("PARKING_LOT")
  isActive     Boolean   @default(true)
  expiresAt    DateTime?

  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parkingLotId])
}

model FavoriteParkingLot {
  id String @id @default(cuid())

  userId       String
  parkingLotId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, parkingLotId])
  @@index([parkingLotId])
}

model ParkingRegistrationPhoto {
  id String @id @default(cuid())

  parkingSessionId String
  imageUrl         String
  photoType        RegistrationPhotoType @default(VEHICLE_PLATE)
  required         Boolean               @default(false)

  capturedByUserId String?
  capturedByRole   String?

  parkingSession ParkingSession @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  capturedBy     User?          @relation(fields: [capturedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([parkingSessionId])
  @@index([capturedByUserId])
}

model WatcherApplication {
  id String @id @default(cuid())

  watcherUserId String
  parkingLotId  String

  status      WatcherApplicationStatus @default(PENDING)
  requestedAt DateTime                 @default(now())

  approvedByUserId String?
  approvedAt       DateTime?
  rejectedByUserId String?
  rejectedAt       DateTime?
  rejectedReason   String?

  watcher    User       @relation("WatcherApplicationWatcher", fields: [watcherUserId], references: [id], onDelete: Cascade)
  approvedBy User?      @relation("WatcherApplicationApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy User?      @relation("WatcherApplicationRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([watcherUserId])
  @@index([parkingLotId, status])
}

model WatcherLotBinding {
  id String @id @default(cuid())

  watcherUserId String
  parkingLotId  String
  status        String @default("ACTIVE")

  watcher    User       @relation(fields: [watcherUserId], references: [id], onDelete: Cascade)
  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([watcherUserId, parkingLotId])
  @@index([parkingLotId])
}

model EnforcementCase {
  id String @id @default(cuid())

  parkingLotId     String
  parkingSectionId String?
  parkingSpaceId   String
  parkingSessionId String

  reason       EnforcementReason
  status       EnforcementCaseStatus @default(OPEN)
  graceMinutes Int

  detectedAt DateTime @default(now())

  assignedToUserId String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  note             String?

  parkingLot     ParkingLot     @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  parkingSession ParkingSession @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  assignedTo     User?          @relation("EnforcementAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  resolvedBy     User?          @relation("EnforcementResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  plateRecognitionResults PlateRecognitionResult[]

  @@index([parkingLotId, status])
  @@index([parkingSessionId])
}

model RegistrationProxyLog {
  id String @id @default(cuid())

  parkingSessionId  String
  performedByUserId String
  performedByRole   String

  vehiclePlateNumber String
  contactPhone       String?
  note               String?

  photoRequired Boolean @default(true)

  parkingSession ParkingSession @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  performedBy    User           @relation(fields: [performedByUserId], references: [id], onDelete: Cascade)

  createdAt                   DateTime                                 @default(now())
  plateRecognitionResults     PlateRecognitionResult[]
  reviewStatus                AuthorityRegistrationReviewStatus        @default(PENDING_REVIEW)
  reviewedByUserId            String?
  reviewedAt                  DateTime?
  reviewNote                  String?
  reviewedBy                  User?                                    @relation("RegistrationProxyLogReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  correctedVehiclePlateNumber String?
  correctedContactPhone       String?
  correctionNote              String?
  correctedByUserId           String?
  correctedAt                 DateTime?
  correctedBy                 User?                                    @relation("RegistrationProxyLogCorrectedBy", fields: [correctedByUserId], references: [id], onDelete: SetNull)
  correctionHistories         AuthorityRegistrationCorrectionHistory[]
  reviewHistories             AuthorityRegistrationReviewHistory[]

  @@index([performedByUserId])
  @@index([parkingSessionId])
  @@index([reviewStatus])
  @@index([reviewedByUserId])
  @@index([correctedByUserId])
  @@index([correctedAt])
}

model InvoiceManualPayment {
  id String @id @default(cuid())

  invoiceId     String
  amount        Int
  paymentMethod String

  collectedByUserId String
  collectedAt       DateTime
  note              String?

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  collectedBy User    @relation(fields: [collectedByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([collectedByUserId])
}

model PlateRecognitionResult {
  id                     String  @id @default(cuid())
  parkingSessionId       String?
  enforcementCaseId      String?
  registrationProxyLogId String?

  imageUrl             String?
  provider             String
  mode                 String
  country              String  @default("KR")
  suggestedPlateNumber String
  reviewedPlateNumber  String?
  confidence           Float?
  candidates           Json?
  rawResponse          Json?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parkingSession       ParkingSession?       @relation(fields: [parkingSessionId], references: [id], onDelete: SetNull)
  enforcementCase      EnforcementCase?      @relation(fields: [enforcementCaseId], references: [id], onDelete: SetNull)
  registrationProxyLog RegistrationProxyLog? @relation(fields: [registrationProxyLogId], references: [id], onDelete: SetNull)
  createdBy            User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([parkingSessionId])
  @@index([enforcementCaseId])
  @@index([registrationProxyLogId])
  @@index([createdByUserId])
  @@index([suggestedPlateNumber])
  @@index([reviewedPlateNumber])
  @@index([createdAt])
}

model AuthorityRegistrationCorrectionHistory {
  id                     String  @id @default(cuid())
  registrationProxyLogId String
  parkingSessionId       String
  correctedByUserId      String?

  previousPlateNumber  String?
  newPlateNumber       String
  previousContactPhone String?
  newContactPhone      String?
  correctionNote       String?

  createdAt DateTime @default(now())

  registrationProxyLog RegistrationProxyLog @relation(fields: [registrationProxyLogId], references: [id], onDelete: Cascade)
  parkingSession       ParkingSession       @relation(fields: [parkingSessionId], references: [id], onDelete: Cascade)
  correctedBy          User?                @relation(fields: [correctedByUserId], references: [id], onDelete: SetNull)

  @@index([registrationProxyLogId])
  @@index([parkingSessionId])
  @@index([correctedByUserId])
  @@index([createdAt])
  @@index([newPlateNumber])
}

model AuthorityRegistrationReviewHistory {
  id                     String  @id @default(cuid())
  registrationProxyLogId String
  reviewedByUserId       String?

  previousStatus AuthorityRegistrationReviewStatus?
  newStatus      AuthorityRegistrationReviewStatus
  reviewNote     String?

  createdAt DateTime @default(now())

  registrationProxyLog RegistrationProxyLog @relation(fields: [registrationProxyLogId], references: [id], onDelete: Cascade)
  reviewedBy           User?                @relation(fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([registrationProxyLogId])
  @@index([reviewedByUserId])
  @@index([newStatus])
  @@index([createdAt])
}

