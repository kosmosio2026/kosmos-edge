//////////////////////////////////////////////////////
// DISPLAY BOARD
//////////////////////////////////////////////////////

model DisplayBoard {
  id String @id @default(cuid())

  // 주차장별 전광판 1개
  parkingLotId String @unique

  name       String
  code       String? @unique
  deviceId   String? @unique
  macAddress String? @unique

  enabled Boolean @default(true)

  // TCP / RS232 / RS485
  transport DisplayTransportType @default(TCP)

  // === TCP 설정 ===
  tcpHost String?
  tcpPort Int?    @default(5000)

  // === Serial / RS485 설정 ===
  serialPort String?
  baudRate   Int?    @default(9600)
  dataBits   Int?    @default(8)
  parity     String? @default("none")
  stopBits   Int?    @default(1)

  connectTimeoutMs Int @default(3000)
  readTimeoutMs    Int @default(3000)

  // === 전광판 프로토콜 설정 ===
  rows       Int  @default(2)
  cols       Int  @default(6)
  moduleType Int?
  rgbOrder   Int?

  brightness Int?    @default(10)
  powerOn    Boolean @default(true)

  // === 표출 모드 ===
  mode DisplayMode @default(AUTO)

  manualReason    String?
  manualExpiresAt DateTime?

  // === Rust daemon 운영 설정 ===
  heartbeatIntervalSec Int @default(15)
  retryMaxAttempts     Int @default(3)
  retryBackoffMs       Int @default(2000)

  // === 상태 ===
  lastHeartbeatAt DateTime?
  lastStatus      DisplayBoardStatus @default(OFFLINE)
  lastError       String?

  lastRenderedPayload Json?
  lastSentPayload     Json?
  lastResponseHex     String?

  lastSentAt DateTime?
  lastAckAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parkingLot ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  lines      DisplayBoardLine[]
  commands   DisplayCommand[]
  heartbeats DisplayHeartbeatLog[]
  modules    DisplayBoardModule[]

  @@index([lastStatus])
  @@index([mode])
  @@index([enabled])
}

model DisplayBoardLine {
  id String @id @default(cuid())

  displayBoardId String
  source         DisplayLineSource

  lineNo Int

  textTemplate String
  enabled      Boolean @default(true)

  fontSize Int     @default(1)
  effect   String  @default("090009000900")
  speed    Int     @default(2)
  delay    Int     @default(5)
  neon     Int     @default(0)
  fix      Boolean @default(false)

  colorCode     Int? @default(0)
  fontCode      Int? @default(0)
  widthCode     Int? @default(1)
  attributeCode Int? @default(0)
  iconCode      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  displayBoard DisplayBoard @relation(fields: [displayBoardId], references: [id], onDelete: Cascade)

  @@unique([displayBoardId, source, lineNo])
  @@index([displayBoardId, source])
}

model DisplayCommand {
  id String @id @default(cuid())

  displayBoardId String

  type    String
  payload Json?

  status DisplayCommandStatus @default(PENDING)

  packetHex   String?
  responseHex String?

  errorMessage String?

  requestedByUserId String?
  requestedAt       DateTime @default(now())

  processingAt DateTime?
  sentAt       DateTime?
  ackedAt      DateTime?
  failedAt     DateTime?

  attempts Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  displayBoard DisplayBoard @relation(fields: [displayBoardId], references: [id], onDelete: Cascade)

  @@index([displayBoardId, status])
  @@index([status, requestedAt])
}

model DisplayHeartbeatLog {
  id String @id @default(cuid())

  displayBoardId String

  status DisplayBoardStatus

  transport          DisplayTransportType?
  lastDisplayedState Json?
  errorDetails       String?

  receivedAt DateTime @default(now())

  displayBoard DisplayBoard @relation(fields: [displayBoardId], references: [id], onDelete: Cascade)

  @@index([displayBoardId, receivedAt])
}

model ColorPreset {
  id    Int    @id
  code  Int // 0~49
  label String // 예: "흰색/검정/투명"
}

model TextAttribute {
  id    Int    @id
  code  Int // 0~17
  label String // 예: "효과없음", "깜빡임"
}

model FontPreset {
  id   Int    @id
  code Int // 0~4
  name String // 굴림, 궁서, 바탕, 고딕, 돋움
}

model WidthPreset {
  id    Int    @id
  code  Int // 1~4
  label String // 장평 1~4
}

model IconPreset {
  id    Int    @id
  code  Int // 1~52
  label String // 느낌표, 당구장1, ...
}

model EffectPreset {
  id    Int    @id @default(autoincrement())
  xx    Int // 1~9
  yy    Int // 0~49 등
  label String // 설명

  @@unique([xx, yy])
}

