{
  "compilerOptions": {
        "baseUrl": ".",
    "paths": {
      "@prisma/client": ["./node_modules/@prisma/client"]
    },
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "prisma/**/*.ts"]
}
